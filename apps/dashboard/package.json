    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "better-sqlite3": "12.10.0",
    "nuxt": "3.21.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vue-tsc": "3.1.5"
  }
}
