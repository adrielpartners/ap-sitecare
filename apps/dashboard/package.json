{
  "name": "@ap-sitecare/dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "mcp": "node --import tsx mcp/server.ts",
    "backup-worker": "node --import tsx worker/backup-worker.ts",
